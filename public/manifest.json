{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "TFT Companion",
    "version": "1.0.0",
    "minimum-overwolf-version": "0.220.0",
    "description": "TFT in-game overlay and desktop companion"
  },
  "permissions": ["GameEvents", "GameInfo"],
  "data": {
    "start_window": "background",
    "windows": {
      "background": {
        "file": "background.html",
        "show_in_taskbar": false,
        "transparent": false,
        "resizable": false,
        "size": { "width": 400, "height": 300 },
        "start_position": { "top": 0, "left": 0 },
        "topmost": false,
        "use_os_windowing": false,
        "desktop_only": false
      },
      "desktop": {
        "file": "desktop.html",
        "show_in_taskbar": true,
        "transparent": false,
        "resizable": true,
        "size": { "width": 900, "height": 650 },
        "start_position": { "top": 200, "left": 200 },
        "topmost": false
      },
      "overlay": {
        "file": "overlay.html",
        "show_in_taskbar": false,
        "transparent": true,
        "resizable": false,
        "size": { "width": 1920, "height": 1080 },
        "start_position": { "top": 0, "left": 0 },
        "topmost": true,
        "in_game_only": true,
        "draw_click_through_on_transparent_area": true,
        "use_os_windowing": false
      }
    },
    "game_targeting": {
      "type": "dedicated",
      "game_ids": [21570]
    },
    "game_events": [
      {
        "game_ids": [21570],
        "events": ["match_start", "match_end"],
        "info_updates": [
          "game_info", "match_info", "active_player", "board", "shop", "roster", "items"
        ]
      }
    ]
  }
}
