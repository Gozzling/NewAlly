{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "uid": "tft-ally-dev-001",
    "name": "TFT Companion",
    "author": "TFT Ally",
    "version": "1.0.0",
    "minimum-overwolf-version": "0.220.0",
    "description": "TFT in-game overlay and desktop companion"
  },
  "permissions": ["GameEvents", "GameInfo", "Hotkeys"],
  "data": {
    "start_window": "background",
    "windows": {
      "background": {
        "file": "background.html",
        "show_in_taskbar": false,
        "transparent": false,
        "resizable": false,
        "size": { "width": 400, "height": 300 },
        "start_position": { "top": 0, "left": 0 },
        "topmost": false,
        "use_os_windowing": false,
        "desktop_only": false
      },
      "desktop": {
        "file": "desktop.html",
        "show_in_taskbar": true,
        "transparent": false,
        "resizable": true,
        "size": { "width": 900, "height": 650 },
        "start_position": { "top": 200, "left": 200 },
        "topmost": false
      },
      "overlay": {
        "file": "overlay.html",
        "show_in_taskbar": false,
        "transparent": true,
        "resizable": false,
        "size": { "width": 1920, "height": 1080 },
        "start_position": { "top": 0, "left": 0 },
        "topmost": true,
        "in_game_only": true,
        "draw_click_through_on_transparent_area": true,
        "use_os_windowing": false
      },
      "lobby": {
        "file": "lobby.html",
        "show_in_taskbar": false,
        "transparent": false,
        "resizable": false,
        "size": { "width": 320, "height": 480 },
        "start_position": { "top": 100, "left": 100 },
        "topmost": true,
        "in_game_only": true
      }
    },
    "hotkeys": {
      "toggle_overlay": {
        "title": "Toggle Overlay",
        "action-type": "custom",
        "default": "Ctrl+T"
      }
    }
  }
}
