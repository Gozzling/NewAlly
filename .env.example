# ── Required for production / Overwolf builds (Riot-compliant) ─────────────
# Riot API key must ONLY live in Supabase secrets — never in the client bundle.
# Deploy Edge Functions and set:
#   supabase secrets set RIOT_API_KEY=rgapi-...

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Never enable in store / distributed builds ───────────────────────────────
# When true, the app may call Riot from the browser using
#   localStorage['tft-ally::riot-api-key']
# Riot policy: personal keys in shipped clients are not allowed. Use only for
# local development when Supabase is unavailable.
# VITE_ALLOW_CLIENT_RIOT_KEY=true

# Optional: absolute URL to this policy for store / Riot forms (defaults to /privacy.html in-app)
# VITE_PRIVACY_POLICY_URL=https://your-username.github.io/TFTAllyMain/privacy.html
# VITE_TERMS_OF_SERVICE_URL=https://your-username.github.io/TFTAllyMain/terms.html
